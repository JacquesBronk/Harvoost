{
  "name": "@harvoost/web",
  "version": "0.1.0",
  "private": true,
  "description": "Harvoost web app — Next.js 14 App Router. Dashboards, timesheets, chatbot, leave & approvals.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "start:standalone": "PORT=3000 node .next/standalone/apps/web/server.js",
    "lint": "next lint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next .turbo node_modules/.cache",
    "generate-types": "tsx scripts/generate-types.ts"
  },
  "dependencies": {
    "@harvoost/ui": "workspace:*",
    "@tanstack/react-query": "^5.59.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.451.0",
    "luxon": "^3.5.0",
    "next": "^14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@tanstack/react-query-devtools": "^5.59.0",
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.10.0",
    "eslint-config-next": "^14.2.15",
    "openapi-typescript": "^7.4.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  }
}
