{
  "name": "@harvoost/api",
  "version": "0.1.0",
  "private": true,
  "description": "Harvoost NestJS API — auth, time tracking, RBAC, chatbot, approvals, exports.",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:worker": "WORKER_MODE=1 node dist/main.js",
    "dev": "ts-node --project tsconfig.json --transpile-only src/main.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.24.0",
    "@harvoost/db": "workspace:^",
    "@harvoost/jobs": "workspace:*",
    "@harvoost/shared": "workspace:*",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.2.1",
    "cookie-parser": "^1.4.6",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "helmet": "^7.1.0",
    "jose": "^5.9.0",
    "luxon": "^3.5.0",
    "nestjs-pino": "^4.1.0",
    "pg-boss": "^9.0.3",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "@prisma/client": "^5.18.0"
  },
  "peerDependenciesMeta": {
    "@prisma/client": {
      "optional": true
    }
  }
}
