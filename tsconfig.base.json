{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "useDefineForClassFields": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    "preserveWatchOutput": true,
    "incremental": true,
    "paths": {
      "@harvoost/db": ["./packages/db/src/index.ts"],
      "@harvoost/db/*": ["./packages/db/src/*"],
      "@harvoost/shared": ["./packages/shared/src/index.ts"],
      "@harvoost/shared/*": ["./packages/shared/src/*"],
      "@harvoost/ui": ["./packages/ui/src/index.ts"],
      "@harvoost/ui/*": ["./packages/ui/src/*"],
      "@harvoost/jobs": ["./packages/jobs/src/index.ts"],
      "@harvoost/jobs/*": ["./packages/jobs/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "build", "coverage", ".turbo"]
}
