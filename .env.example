# Harvoost environment variables — example file
# Copy to .env.local (root) or use with docker-compose. NEVER commit a real .env.
#
# For local development with `docker compose up -d`, the dev defaults below
# are sufficient. For production, all __REPLACE_ME__ values must be filled in
# from Azure Key Vault at deploy time.

# ----- Identity / Auth (OIDC — provider-agnostic per ADR-0001) -----
# Dev: Keycloak in docker-compose (issuer URL is the dev default below).
# Prod: Entra ID — set OIDC_ISSUER_URL to https://login.microsoftonline.com/<tenant-id>/v2.0
#       and populate OIDC_CLIENT_ID + OIDC_CLIENT_SECRET from your App Registration.
OIDC_ISSUER_URL=http://localhost:8080/realms/harvoost
OIDC_CLIENT_ID=harvoost-web
OIDC_CLIENT_SECRET=dev-keycloak-client-secret-not-for-prod
OIDC_REDIRECT_URI_WEB=http://localhost:3000/v1/auth/callback
OIDC_REDIRECT_URI_TRAY=harvoost://auth/callback

# ----- Database -----
# Local: docker-compose Postgres. Prod: Azure Database for PostgreSQL Flexible Server.
DATABASE_URL=postgresql://harvoost:dev@localhost:5432/harvoost?sslmode=disable
SHADOW_DATABASE_URL=postgresql://harvoost:dev@localhost:5432/harvoost_shadow?sslmode=disable

# ----- Storage -----
# Local: Azurite emulator (well-known dev account). Prod: Azure Blob Storage.
BLOB_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://localhost:10000/devstoreaccount1;
BLOB_EXPORTS_CONTAINER=exports

# ----- Observability -----
# REQUIRED for prod. Unset locally -> OTel disabled, logs to stdout.
APPINSIGHTS_CONNECTION_STRING=

# ----- LLM provider (default = OpenAI per r2) -----
# Exactly ONE provider key must match LLM_PROVIDER. Use `mock` for offline dev.
LLM_PROVIDER=mock
LLM_MODEL_ID=gpt-4o
# REQUIRED for production deploy with LLM_PROVIDER=openai:
OPENAI_API_KEY=__REPLACE_ME__
# Optional — only if LLM_PROVIDER is overridden:
# ANTHROPIC_API_KEY=__REPLACE_ME__
# GOOGLE_GENERATIVE_AI_API_KEY=__REPLACE_ME__
# XAI_API_KEY=__REPLACE_ME__
# OLLAMA_BASE_URL=http://localhost:11434

# ----- Email -----
# Local: Maildev (http://localhost:1080). Prod: Azure Communication Services.
ACS_EMAIL_CONNECTION_STRING=
ACS_EMAIL_SENDER_ADDRESS=noreply@harvoost.local

# ----- Sessions -----
# REGENERATE for production (use `openssl rand -base64 32`).
SESSION_SECRET=dev-session-secret-not-for-prod-replace-with-random-32-bytes
AUDIT_HASH_SECRET=dev-audit-secret-not-for-prod-replace-with-random-32-bytes

# ----- Bootstrap -----
# Email seeded into admin_email_allowlist; first OIDC login matching this email becomes admin.
# Dev default matches the Keycloak realm-import's `alice@harvoost.local`.
BOOTSTRAP_ADMIN_EMAIL=admin@harvoost.local

# ----- Test-only bypass (NEVER set this outside NODE_ENV=test) -----
# When TEST_AUTH_BYPASS=1 AND NODE_ENV=test, the API accepts X-Test-User-Id headers
# for unit/integration tests. The boot invariant refuses this combination in any
# other env. Use the `mintTestSession()` helper for integration tests instead.
# TEST_AUTH_BYPASS=0

# ----- Other -----
NODE_ENV=development
PORT=3001
CORS_ALLOWED_ORIGINS=http://localhost:3000
WEB_ORIGIN=http://localhost:3000
# WORKER_MODE=1   # set in the worker process only (no HTTP)
# REDIS_URL=      # optional v1.1 (in-process rate limiter is fine without)

# ----- Exception detection thresholds (worker process) -----
# Defaults per REQUIREMENTS F8.2 / F8.3. Override per-org if FinMgr stakeholder
# tunes the policy. Numbers are positive decimals; non-positive values reset to default.
# OT_DAY_THRESHOLD_HOURS=10
# OT_WEEK_THRESHOLD_HOURS=50
# ANOMALY_STDEV_THRESHOLD=2.0
