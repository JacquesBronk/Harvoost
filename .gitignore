# HackTogether runtime state.
# Top-level files (e.g. secrets.local.md) stay ignored; the runs/ tree is
# committed because it captures the agentic SDLC artefacts for this repo.
.hacktogether/*
!.hacktogether/runs/

# Secrets
.env
.env.*
!.env.example

# OS / editor noise
.DS_Store
*.swp
.vscode/
.idea/

# Common build outputs (added per the system the orchestrator builds here)
node_modules/
__pycache__/
*.pyc
dist/
build/
out/
.next/
.turbo/
coverage/
*.log
*.tsbuildinfo
playwright-report/
test-results/
